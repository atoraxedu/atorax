{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-demos",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/auto-assign",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "30 2 * * 1"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "30 5 * * 2"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "30 7 * * 3"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "30 10 * * 4"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "30 12 * * 5"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "30 5 * * 6"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "30 7 * * 0"
    },
    {
      "path": "/api/cron/monthly-attendance",
      "schedule": "30 15 1 * *"
    }
  ]
}